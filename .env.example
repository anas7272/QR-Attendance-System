# ─────────────────────────────────────────────────────────
#  .env  —  QR Attendance System  (NEVER commit this file!)
# ─────────────────────────────────────────────────────────

# Your Oracle Cloud server's public IP or domain
APP_URL=https://YOUR_DOMAIN_OR_IP

# Flask secret key — change this to a random string!
SECRET_KEY=change-me-to-something-random-and-long

# ── Google Sheets ──────────────────────────────────────
GOOGLE_CREDS_FILE=credentials.json
SHEET_NAME=Attendance System

# ── SMS Provider ───────────────────────────────────────
# Choose: 'fast2sms'  (India, cheap)
#      or 'twilio'   (international)
SMS_PROVIDER=fast2sms

# fast2sms  (get key from https://www.fast2sms.com)
FAST2SMS_KEY=YOUR_FAST2SMS_API_KEY

# Twilio  (get from https://www.twilio.com)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token
TWILIO_FROM=+1XXXXXXXXXX

# ── Debug (set to 'true' to show OTP on screen, no SMS) ─
DEBUG_MODE=false
